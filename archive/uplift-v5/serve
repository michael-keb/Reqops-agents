#!/usr/bin/env bash
# Uplift v5 UI — one Cursor `agent` CLI process per discovery session.
set -euo pipefail
ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

OPEN=""
for arg in "$@"; do
  [[ "$arg" == "--open" ]] && OPEN="--open"
done

# Never use legacy spawn-per-turn
unset UPLIFT_SPAWN_AGENT

if ! command -v agent >/dev/null 2>&1; then
  echo "Cursor agent CLI not found. Install:" >&2
  echo "  curl https://cursor.com/install -fsS | bash && agent login" >&2
  exit 1
fi

PORT="${UPLIFT_UI_PORT:-8785}"
if command -v lsof >/dev/null 2>&1; then
  lsof -ti ":$PORT" | xargs kill -9 2>/dev/null || true
fi

PY=python3
if [[ -x "$ROOT/.venv/bin/python" ]]; then
  PY="$ROOT/.venv/bin/python"
fi

exec "$PY" bridge/server.py $OPEN
