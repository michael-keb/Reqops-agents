{
  "name": "uplift-v6",
  "private": true,
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:latency": "playwright test tests/e2e/latency.spec.ts",
    "test:e2e:health": "playwright test tests/e2e/ui-health.spec.ts",
    "test:e2e:real": "UPLIFT_E2E_REAL=1 playwright test --config playwright.real.config.ts",
    "test:unit": "python -m unittest discover -s tests -p 'test_*.py'"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  }
}
