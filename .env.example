# Copy to .env and fill in values (never commit .env).
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# Optional
# OPENAI_BASE_URL=https://api.openai.com/v1
# RUBRIC_MODEL=gpt-4o
RUBRIC_FILE=llm-rubric.md

# Output sections per LLM call (1/on/true/yes = include, 0/off/false/no = omit)
# State codes are always required when enabled; disable only if you know what you're doing.
OUTPUT_REFLECTION=1
OUTPUT_STATE_CODES=1
OUTPUT_NARRATIVE=1
OUTPUT_QUESTIONS=1
OUTPUT_MEMORY_PATCH=1

# Example: state codes only (faster, smaller completion)
# OUTPUT_REFLECTION=0
# OUTPUT_STATE_CODES=1
# OUTPUT_NARRATIVE=0
# OUTPUT_QUESTIONS=0
# OUTPUT_MEMORY_PATCH=0
