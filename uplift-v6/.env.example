# Uplift v6 bridge (ReqOps integration sidecar)
UPLIFT_PORT=8786
# headless = per-turn `agent` subprocess + stream-json (recommended for ReqOps)
# pty = interactive terminal UI
UPLIFT_AGENT_MODE=headless
# UPLIFT_MOCK_AGENT=1

# SDK runner (agent-sdk = CLI-as-a-service; default for deploy)
# UPLIFT_DISCOVERY_RUNNER=sdk
# UPLIFT_SIGNALS_RUNNER=sdk
# UPLIFT_AGENT_SDK_URL=http://127.0.0.1:7778
# UPLIFT_SDK_PROVIDER=unix_local
# UPLIFT_SDK_AGENT_TYPE=cursor
