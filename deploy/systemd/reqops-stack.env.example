# Copy to /etc/reqops-stack.env and edit paths for your VPS.

REQOPS_AGENTS_ROOT=/opt/Reqops-agents
REQOPS_ROOT=/opt/Thinkfast-book/ReqOps
CALL_BACKUP=/opt/Reqops-agents

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
POSTGRES_DB=thoughtweaver

CURSOR_API_KEY=
AGENT_SDK_ORIGIN=production
AGENT_SDK_LOCAL_VOL_ROOT=/var/lib/reqops/agent-sdk-volumes

DISCOVERY_ENGINE=uplift
UPLIFT_BRIDGE_URL=http://127.0.0.1:8786
UPLIFT_AGENT_SDK_URL=http://127.0.0.1:7778
UPLIFT_AGENT_MODE=headless
UPLIFT_DISCOVERY_RUNNER=sdk
UPLIFT_SIGNALS_RUNNER=sdk
UPLIFT_SDK_PROVIDER=unix_local
UPLIFT_SDK_AGENT_TYPE=cursor

# Only when UPLIFT_SDK_PROVIDER=daytona:
# DAYTONA_API_KEY=

CORS_ORIGINS=http://your-vps-ip,https://app.yourdomain.com
