# Production .env for droplet deploy (Auth0 enabled, no dev bypass).
# Copy to .env on the server: cp deploy/production.env.example .env

CURSOR_API_KEY=
REQOPS_ROOT=/opt/ReqOps

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=postgres

PUBLIC_HOST=app.reqops.com
PUBLIC_ORIGIN=https://app.reqops.com
HTTP_PORT=80
HTTPS_PORT=443
CORS_ORIGINS=https://app.reqops.com
VITE_WS_BASE_URL=wss://app.reqops.com/api/v1/ws

# Auth0 — tenant reqops, SPA Staging-Reqops (ID token auth; audience = client_id)
AUTH0_DOMAIN=reqops.au.auth0.com
AUTH0_ISSUER=https://reqops.au.auth0.com/
AUTH0_AUDIENCE=kP5WPBHJmk97JQEYOtN2ToMsoMC8dP90
VITE_AUTH0_DOMAIN=reqops.au.auth0.com
VITE_AUTH0_CLIENT_ID=kP5WPBHJmk97JQEYOtN2ToMsoMC8dP90

# Leave empty in production (forces real Auth0 login)
DEV_USER_SUB=
DEV_USER_EMAIL=
VITE_DEV_AUTH_BYPASS=

# Commit board — intent extraction via ReqOps backend (OpenAI)
VITE_COMMIT_BOARD_API_ENABLED=true
VITE_COMMIT_BOARD_API_URL=/api/v1

UPLIFT_SDK_PROVIDER=unix_local
AGENT_SDK_ORIGIN=production

# Optional: patch Auth0 callback URLs via Management API (see configure-auth0-app.sh)
# AUTH0_MGMT_CLIENT_ID=
# AUTH0_MGMT_CLIENT_SECRET=

# --- Freemium + Stripe (test keys OK for initial rollout) ---
ALLOW_GUEST=1
# COOKIE_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_TEAM=
STRIPE_SUCCESS_URL=https://app.reqops.com/?upgraded=1
STRIPE_CANCEL_URL=https://app.reqops.com/
