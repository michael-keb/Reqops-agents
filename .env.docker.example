# Copy to .env before: docker compose up -d --build
# cp .env.docker.example .env

# --- Required ---
CURSOR_API_KEY=

# --- Paths (ReqOps lives outside this repo by default) ---
REQOPS_ROOT=../Thinkfast book/ReqOps

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=postgres

# --- Public URL (used at frontend build time for WebSockets) ---
# Local docker:
VITE_WS_BASE_URL=ws://localhost/api/v1/ws
CORS_ORIGINS=http://localhost
HTTP_PORT=80

# Production example (rebuild frontend after changing):
# VITE_WS_BASE_URL=wss://app.yourdomain.com/api/v1/ws
# CORS_ORIGINS=https://app.yourdomain.com
# HTTP_PORT=80

# --- Agent execution (CLI-as-a-service via agent-sdk) ---
# uplift calls agent-sdk; agent-sdk runs the Cursor CLI (not uplift).
# Single-server default: unix_local (CLI inside agent-sdk container).
UPLIFT_SDK_PROVIDER=unix_local
UPLIFT_SDK_AGENT_TYPE=cursor
AGENT_SDK_ORIGIN=production

# Only when UPLIFT_SDK_PROVIDER=daytona (isolated cloud sandboxes):
# DAYTONA_API_KEY=

# Optional LLM keys (agent-sdk multi-provider)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- ReqOps auth (production — see deploy/production.env.example) ---
AUTH0_DOMAIN=reqops.au.auth0.com
AUTH0_ISSUER=https://reqops.au.auth0.com/
AUTH0_AUDIENCE=kP5WPBHJmk97JQEYOtN2ToMsoMC8dP90
VITE_AUTH0_DOMAIN=reqops.au.auth0.com
VITE_AUTH0_CLIENT_ID=kP5WPBHJmk97JQEYOtN2ToMsoMC8dP90
# Leave empty — real Auth0 login required:
# DEV_USER_SUB=
# VITE_DEV_AUTH_BYPASS=

# --- Workshop / uplift ---
# UPLIFT_INTERNAL_TOKEN=shared-secret-between-backend-and-bridge
# VITE_DEV_AUTH_BYPASS=1
